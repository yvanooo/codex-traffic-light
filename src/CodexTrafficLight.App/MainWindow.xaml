<Window x:Class="CodexTrafficLight.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="100"
        Height="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid x:Name="Root">
        <StackPanel x:Name="Shell" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
            <Border x:Name="Body"
                    Width="80"
                    Height="200"
                    CornerRadius="24"
                    Background="#2B2B2B"
                    HorizontalAlignment="Center"
                    MouseLeftButtonDown="Body_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect Color="#111111" BlurRadius="18" ShadowDepth="4" Opacity="0.55"/>
                </Border.Effect>
                <Grid Margin="0,8,0,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid x:Name="RedLampHost" Width="64" Height="48" Margin="0,1">
                            <Ellipse x:Name="RedRing" Width="44" Height="44" Opacity="0" IsHitTestVisible="False"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="RedWell" Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse x:Name="RedLamp" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="YellowLampHost" Width="64" Height="48" Margin="0,1">
                            <Ellipse x:Name="YellowRing" Width="44" Height="44" Opacity="0" IsHitTestVisible="False"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="YellowWell" Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse x:Name="YellowLamp" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="GreenLampHost" Width="64" Height="48" Margin="0,1">
                            <Ellipse x:Name="GreenRing" Width="44" Height="44" Opacity="0" IsHitTestVisible="False"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="GreenWell" Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse x:Name="GreenLamp" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Width="30"
                          Height="28"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0">
                        <Button x:Name="GearButton"
                                Width="24"
                                Height="24"
                                Content="⚙"
                                FontSize="12"
                                Foreground="#D8D8D8"
                                Background="#666666"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Click="GearButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="12" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <Border x:Name="SessionCountBadge"
                            Grid.RowSpan="2"
                            MinWidth="24"
                            Height="14"
                            CornerRadius="8"
                            Background="#FF9F0A"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,4,26"
                            Panel.ZIndex="10"
                            MouseLeftButtonDown="SessionCountBadge_MouseLeftButtonDown"
                            Visibility="Collapsed">
                        <TextBlock x:Name="SessionCountText"
                                   Text="0"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="#171717"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="4,0"/>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="SettingsPanel"
                    Width="100"
                    Height="70"
                    CornerRadius="14"
                    Background="#2A2A2A"
                    Margin="0,8,0,0"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <CheckBox x:Name="MuteCheckBox"
                              Content="静音"
                              Foreground="White"
                              Margin="4"
                              Checked="MuteCheckBox_Changed"
                              Unchecked="MuteCheckBox_Changed"/>
                    <CheckBox x:Name="ThemeCheckBox"
                              Content="深色"
                              Foreground="White"
                              Margin="4"
                              Checked="ThemeCheckBox_Changed"
                              Unchecked="ThemeCheckBox_Changed"/>
                </StackPanel>
            </Border>
        </StackPanel>
            <Border x:Name="SessionDrawer"
                    Width="252"
                    Height="200"
                    CornerRadius="18"
                    Background="#F7202124"
                    Margin="10,8,0,0"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect Color="#111111" BlurRadius="24" ShadowDepth="6" Opacity="0.35"/>
                </Border.Effect>
                <Grid>
                    <Border x:Name="SessionDrawerAccent"
                            Width="3"
                            Height="148"
                            CornerRadius="0,4,4,0"
                            Background="#FF9F0A"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"/>
                    <StackPanel Margin="10,9,10,9">
                        <Grid Margin="4,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SessionDrawerTitle"
                                       Text="Codex 任务"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="12"/>
                            <TextBlock x:Name="SessionDrawerSortLabel"
                                       Grid.Column="1"
                                       Text="按优先级排序"
                                       Foreground="#A8A8B0"
                                       FontSize="10"/>
                        </Grid>
                        <Border x:Name="SessionDrawerDivider" Height="1" Background="#22FFFFFF" Margin="0,0,0,1"/>
                        <ScrollViewer x:Name="SessionScrollViewer"
                                      Height="150"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly">
                            <StackPanel x:Name="SessionListPanel"/>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
