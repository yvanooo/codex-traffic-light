<Window x:Class="CodexTrafficLight.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="360"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6F8">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="设置"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1F2228"
                   Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="外观" FontWeight="Bold" Foreground="#3A3E46" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="显示方式" VerticalAlignment="Center" Foreground="#5B606A"/>
                    <ComboBox x:Name="StyleComboBox" Grid.Column="1" VerticalAlignment="Center">
                        <ComboBoxItem Content="三灯" Tag="triple"/>
                        <ComboBoxItem Content="单灯" Tag="single"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Text="主题" VerticalAlignment="Center" Foreground="#5B606A"/>
                    <ComboBox x:Name="ThemeComboBox" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                        <ComboBoxItem Content="深色" Tag="dark"/>
                        <ComboBoxItem Content="浅色" Tag="light"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Text="窗口" VerticalAlignment="Center" Foreground="#5B606A"/>
                    <CheckBox x:Name="TopmostCheckBox" Grid.Row="2" Grid.Column="1" Content="窗口置顶" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="灯效" FontWeight="Bold" Foreground="#3A3E46" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="模式" VerticalAlignment="Center" Foreground="#5B606A"/>
                    <ComboBox x:Name="LampEffectComboBox" Grid.Column="1" VerticalAlignment="Center">
                        <ComboBoxItem Content="呼吸闪动" Tag="breath"/>
                        <ComboBoxItem Content="常亮" Tag="steady"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Text="速度" VerticalAlignment="Center" Foreground="#5B606A"/>
                    <ComboBox x:Name="LampSpeedComboBox" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                        <ComboBoxItem Content="慢" Tag="slow"/>
                        <ComboBoxItem Content="标准" Tag="standard"/>
                        <ComboBoxItem Content="快" Tag="fast"/>
                    </ComboBox>
                </Grid>

                <TextBlock Text="任务" FontWeight="Bold" Foreground="#3A3E46" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,14">
                    <CheckBox x:Name="AutoOpenDrawerCheckBox" Content="黄灯时自动展开任务列表" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ShowEndedSessionsCheckBox" Content="显示已结束会话" Margin="0,0,0,8"/>
                    <CheckBox x:Name="MutedCheckBox" Content="静音"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="78" Height="30" Margin="0,0,8,0" Content="取消" IsCancel="True"/>
            <Button Width="78" Height="30" Content="保存" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
